# =============================================================
# FELIX TRAVEL - Environment Variables Reference
# =============================================================
# Copy this file to .env.local (never commit .env.local)
# See docs/env.md for full documentation of every variable
# =============================================================

# -----------------------------------------------
# CORE APPLICATION
# -----------------------------------------------

# Application environment: development | staging | production
APP_ENV=development

# Human-readable platform name used in emails, UI, metadata
APP_NAME="Felix Travel"

# Base URL of this instance (no trailing slash)
APP_BASE_URL=http://localhost:8787

# URL where customer-facing frontend is hosted
CUSTOMER_APP_URL=http://localhost:3000

# URL where admin/agent/provider dashboard is hosted
DASHBOARD_APP_URL=http://localhost:3001

# Public API base URL (used by SDKs and frontend clients)
API_BASE_URL=http://localhost:8787

# Default timezone for date display and scheduling (IANA format)
DEFAULT_TIMEZONE=Africa/Nairobi

# ISO 4217 currency code for platform default currency
DEFAULT_CURRENCY=KES

# ISO 3166-1 alpha-2 country code for platform home country
PLATFORM_COUNTRY_CODE=KE

# -----------------------------------------------
# AUTH / SECURITY
# -----------------------------------------------

# JWT issuer claim — must match audience in token validation
JWT_ISSUER=https://api.felix.travel

# JWT audience claim — frontend apps must send this
JWT_AUDIENCE=felix-travel-clients

# Access token TTL in seconds (15 minutes default)
JWT_ACCESS_TTL_SECONDS=900

# Refresh token TTL in seconds (30 days default)
JWT_REFRESH_TTL_SECONDS=2592000

# RS256 private key in PEM format (base64-encoded for env safety)
# Generate: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 | base64 -w 0
JWT_PRIVATE_KEY=base64_encoded_rsa_private_key_here

# RS256 public key in PEM format (base64-encoded)
# Generate: openssl rsa -pubout -in private.pem | base64 -w 0
JWT_PUBLIC_KEY=base64_encoded_rsa_public_key_here

# Name of the session cookie set on browsers
SESSION_COOKIE_NAME=felix_session

# Whether the session cookie should be Secure (true in prod)
SESSION_COOKIE_SECURE=false

# Domain scope for session cookie (e.g. .felix.travel in prod)
SESSION_COOKIE_DOMAIN=localhost

# Magic link expiry in minutes
MAGIC_LINK_TTL_MINUTES=15

# Password reset link expiry in minutes
PASSWORD_RESET_TTL_MINUTES=60

# OTP expiry in minutes
OTP_TTL_MINUTES=10

# Bcrypt/Argon2 cost factor for password hashing (higher = slower)
PASSWORD_HASH_COST=12

# HMAC algorithm for signing outbound webhook payloads
HMAC_WEBHOOK_SIGNING_ALGO=SHA-256

# Secret used to sign internal task/event messages
# Generate: openssl rand -hex 32
INTERNAL_EVENT_SIGNING_SECRET=change_me_generate_with_openssl_rand_hex_32

# CSRF token signing secret
# Generate: openssl rand -hex 32
CSRF_SECRET=change_me_generate_with_openssl_rand_hex_32

# AES-256-GCM encryption key for at-rest sensitive fields (base64)
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_base64_32

# How long audit log entries are retained (days)
AUDIT_LOG_RETENTION_DAYS=365

# -----------------------------------------------
# EMAIL / NOTIFICATIONS
# -----------------------------------------------

# Email provider: resend | sendgrid | mailgun | smtp
EMAIL_PROVIDER=resend

# Sender address for all platform emails
EMAIL_FROM="Felix Travel <no-reply@felix.travel>"

# Resend API key (required when EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SMS provider: africas_talking | twilio | disabled
SMS_PROVIDER=africas_talking

# SMS sender ID shown to recipients
SMS_SENDER_ID=FELIX

# Africa's Talking API key (when SMS_PROVIDER=africas_talking)
AT_API_KEY=atsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Africa's Talking username
AT_USERNAME=felix_travel

# -----------------------------------------------
# TINGG PAYMENT INTEGRATION
# -----------------------------------------------

# Tingg environment: sandbox | production
TINGG_ENVIRONMENT=sandbox

# Tingg API base URL
TINGG_BASE_URL=https://api.tingg.africa/v3

# OAuth2 client ID issued by Tingg
TINGG_CLIENT_ID=your_tingg_client_id

# OAuth2 client secret issued by Tingg (SECRET - never expose)
TINGG_CLIENT_SECRET=your_tingg_client_secret

# Tingg service code for collections
TINGG_SERVICE_CODE=your_service_code

# Tingg service code for payouts (may differ from collections)
TINGG_PAYOUT_SERVICE_CODE=your_payout_service_code

# ISO 3166-1 country code for collection requests
TINGG_COLLECTION_COUNTRY_CODE=KE

# ISO 4217 currency code for collection requests
TINGG_COLLECTION_CURRENCY_CODE=KES

# Callback URL Tingg will POST checkout events to (your public API)
TINGG_CALLBACK_CHECKOUT_URL=https://api.felix.travel/v1/webhooks/tingg/checkout

# Callback URL Tingg will POST payout events to (your public API)
TINGG_CALLBACK_PAYOUT_URL=https://api.felix.travel/v1/webhooks/tingg/payout

# URL Tingg redirects to after successful payment
TINGG_SUCCESS_REDIRECT_URL=https://www.felix.travel/payment/success

# URL Tingg redirects to after failed payment
TINGG_FAIL_REDIRECT_URL=https://www.felix.travel/payment/failed

# How long to cache Tingg OAuth tokens in KV (seconds, <3600 recommended)
TINGG_TOKEN_CACHE_TTL_SECONDS=3300

# HTTP timeout for Tingg API calls in milliseconds
TINGG_HTTP_TIMEOUT_MS=30000

# Maximum number of retries for failed Tingg requests
TINGG_MAX_RETRIES=3

# Optional: comma-separated IP allowlist for Tingg webhook source IPs
# TINGG_WEBHOOK_IP_ALLOWLIST=196.201.214.0/24,196.201.215.0/24

# Optional: default payment option code (e.g. MPESA, CARD)
# TINGG_DEFAULT_PAYMENT_OPTION_CODE=MPESA_KE

# -----------------------------------------------
# STORAGE / MEDIA
# -----------------------------------------------

# Public base URL for R2 bucket (via Cloudflare custom domain)
R2_PUBLIC_BASE_URL=https://media.felix.travel

# Maximum allowed upload size in megabytes
MEDIA_MAX_UPLOAD_MB=20

# Comma-separated list of allowed MIME types for uploads
MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,application/pdf

# -----------------------------------------------
# OPERATIONS / SCHEDULING
# -----------------------------------------------

# Cron expression for reconciliation job
RECONCILIATION_CRON_SCHEDULE="0 2 * * *"

# Cron expression for payout disbursement job
PAYOUT_CRON_SCHEDULE="0 9 * * 1-5"

# Cron expression for polling pending payments
PENDING_PAYMENT_POLL_CRON_SCHEDULE="*/5 * * * *"

# Cron expression for polling pending payouts
PENDING_PAYOUT_POLL_CRON_SCHEDULE="*/10 * * * *"

# Logging level: debug | info | warn | error
LOG_LEVEL=debug

# Whether to log every HTTP request/response
ENABLE_REQUEST_LOGGING=true

# Whether to log SQL queries (WARNING: may log PII in dev)
ENABLE_SQL_LOGGING=false

# Feature flags
FEATURE_ENABLE_CROSS_BORDER_PAYOUTS=false
FEATURE_ENABLE_PROVIDER_CALLBACKS=true
FEATURE_ENABLE_AGENT_QUOTES=true
FEATURE_ENABLE_CARD_PAYMENTS=false
FEATURE_ENABLE_EMAIL_NOTIFICATIONS=true
FEATURE_ENABLE_SMS_NOTIFICATIONS=false

# -----------------------------------------------
# RBAC / ADMIN CONTROLS
# -----------------------------------------------

# Days after service date before payout is eligible
DEFAULT_SETTLEMENT_DELAY_DAYS=3

# Refund amounts above this (in minor currency units) require admin approval
REFUND_APPROVAL_THRESHOLD=100000

# Payout amounts above this (in minor currency units) require admin approval
PAYOUT_APPROVAL_THRESHOLD=500000

# Maximum TTL for idempotency keys stored in KV (hours)
MAX_IDEMPOTENCY_TTL_HOURS=24

# Maximum retry attempts for outbound provider callbacks
MAX_WEBHOOK_RETRY_ATTEMPTS=5

# Timeout in ms for outbound provider callback HTTP requests
PROVIDER_CALLBACK_TIMEOUT_MS=10000
